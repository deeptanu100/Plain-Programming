{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "Plain",
    "scopeName": "source.plain",
    "fileTypes": ["plain"],
    "patterns": [
        { "include": "#comments" },
        { "include": "#strings" },
        { "include": "#numbers" },
        { "include": "#booleans" },
        { "include": "#keywords" },
        { "include": "#operators" },
        { "include": "#blocks" }
    ],
    "repository": {
        "comments": {
            "patterns": [
                { "name": "comment.line.double-slash.plain", "match": "//.*$" },
                { "name": "comment.line.note.plain", "match": "(?i)^\\s*note:.*$" }
            ]
        },
        "strings": {
            "patterns": [
                { "name": "string.quoted.double.plain", "begin": "\"", "end": "\"", "patterns": [{ "name": "constant.character.escape.plain", "match": "\\\\." }] },
                { "name": "string.quoted.single.plain", "begin": "'", "end": "'", "patterns": [{ "name": "constant.character.escape.plain", "match": "\\\\." }] }
            ]
        },
        "numbers": {
            "patterns": [
                { "name": "constant.numeric.plain", "match": "\\b-?\\d+(\\.\\d+)?\\b" }
            ]
        },
        "booleans": {
            "patterns": [
                { "name": "constant.language.boolean.plain", "match": "(?i)\\b(true|false|yes|no)\\b" }
            ]
        },
        "keywords": {
            "patterns": [
                {
                    "name": "keyword.control.plain",
                    "match": "(?i)\\b(if|then|else|end|repeat|times|while|for|each|in|return)\\b"
                },
                {
                    "name": "keyword.operator.plain",
                    "match": "(?i)\\b(set|to|add|subtract|from|multiply|divide|by|and|or|is|not|equal|greater|less|than)\\b"
                },
                {
                    "name": "keyword.other.plain",
                    "match": "(?i)\\b(say|show|ask|save|define|using|run|with|create|list|called|remove|item|size|of)\\b"
                }
            ]
        },
        "operators": {
            "patterns": [
                { "name": "keyword.operator.concat.plain", "match": "\\+" }
            ]
        },
        "blocks": {
            "patterns": [
                { "name": "keyword.control.block-end.plain", "match": "(?i)\\b(end\\s+if|end\\s+repeat|end\\s+while|end\\s+for|end\\s+define)\\b" }
            ]
        }
    }
}
